{
  "name": "sockbowl-ng",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "buildprod": "ng build --configuration production",
    "test": "ng test",
    "codegen": "bash scripts/gen-packet-types.sh",
    "gen:cast-tokens": "sass src/cast-theme-tokens.scss src/cast-theme-tokens.css --style=compressed --no-source-map",
    "e2e": "playwright test --project=chromium",
    "clips": "node scripts/build-clips.mjs"
  },
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@angular/service-worker": "^21.2.17",
    "@stomp/rx-stomp": "^2.4.0",
    "@stomp/stompjs": "^7.0.0",
    "angular-oauth2-oidc": "^21.0.3",
    "rxjs": "~7.8.0",
    "sockjs-client": "^1.6.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.18",
    "@angular/cli": "~21.2.18",
    "@angular/compiler-cli": "^21.2.17",
    "@playwright/test": "^1.61.1",
    "@types/jasmine": "^6.0.0",
    "@types/sockjs-client": "^1.5.4",
    "graphql": "^16.14.2",
    "jasmine-core": "~6.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "quicktype": "^23.0.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "http-proxy-middleware": "^3.0.7",
    "@babel/core": "^7.29.7"
  }
